{
  "appId": "com.mile12warrior.app",
  "appName": "Mile 12 Warrior",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "allowNavigation": ["*"],
    "cleartext": true
  },
  "plugins": {
    "StatusBar": {
      "style": "Dark",
      "backgroundColor": "#050608"
    },
    "SplashScreen": {
      "launchAutoHide": true,
      "launchShowDuration": 2000,
      "backgroundColor": "#050608",
      "showSpinner": false
    },
    "Keyboard": {
      "resize": "body",
      "resizeOnFullScreen": true
    }
  },
  "android": {
    "allowMixedContent": true,
    "backgroundColor": "#050608"
  },
  "ios": {
    "backgroundColor": "#050608",
    "preferredContentMode": "mobile",
    "scheme": "Mile12Warrior"
  }
}
