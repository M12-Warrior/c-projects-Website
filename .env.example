# Copy to .env for local development (do not commit .env).
# server.js loads .env automatically via dotenv.

SESSION_SECRET=change-me-in-production

# Persistent storage (Railway): point these at a mounted volume so the database and
# uploaded images survive redeploys. Leave unset locally to use the in-repo defaults.
# DB_PATH=/data/drivershield.db
# UPLOADS_DIR=/data/uploads

# First admin on empty DB (production: set a strong password; never use admin123 in prod)
# ADMIN_INITIAL_PASSWORD=

# Stripe (server + Checkout; do not commit real keys)
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Checkout stays OFF by default (CHECKOUT_PAUSED is true unless set to false).
# Set CHECKOUT_PAUSED=false when the drivers gear shop is ready to sell again.
# CHECKOUT_PAUSED=false

# Email (optional): contact form mirrors to the right inbox when SMTP_* is set
# BOOKING_EMAIL=admin@mile12warrior.com
# GENERAL_EMAIL=joyce@mile12warrior.com
# ADMIN_EMAIL=admin@mile12warrior.com
# FROM_EMAIL=noreply@mile12warrior.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Canonical site URL for links in emails (Railway / production)
# BASE_URL=https://mile12warrior.com
