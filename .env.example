# Copy to .env for local development (do not commit .env).
# server.js loads .env automatically via dotenv.

SESSION_SECRET=change-me-in-production

# Authorize.net (same merchant account for all three; never commit real keys)
# Sandbox: https://sandbox.authorize.net — omit AUTHORIZE_USE_PRODUCTION (or use 0)
# Production: live merchant — set AUTHORIZE_USE_PRODUCTION=1
AUTHORIZE_LOGIN_ID=
# Secret — server only (never expose to the browser)
AUTHORIZE_TRANSACTION_KEY=
# Public Client Key for Accept.js (Account → API Credentials & Keys → Manage Public Client Key)
AUTHORIZE_PUBLIC_CLIENT_KEY=
# Leave unset or 0 for sandbox API + jstest Accept.js; set to 1 for live gateway + js.authorize.net
# AUTHORIZE_USE_PRODUCTION=0

# Email (optional): contact form mirrors to this address when SMTP_* is set
# ADMIN_EMAIL=admin@mile12warrior.com
# FROM_EMAIL=noreply@mile12warrior.com
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Canonical site URL for links in emails (Railway / production)
# BASE_URL=https://mile12warrior.com
